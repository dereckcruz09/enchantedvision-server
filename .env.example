# Copy this to .env and fill in real values. NEVER commit the real .env.

# Path to the Ed25519 private key (PEM format) used to sign tokens.
# Generated with `python keypair.py`.
PRIVATE_KEY_PATH=.keys/private.pem

# Path to the SQLite database that stores keys + revocations.
DB_PATH=.keys/keys.db

# How long an activation token is valid, in seconds. Default: 7 days.
TOKEN_TTL_SECONDS=604800

# Admin API key. Used by EnchantedKeyGen.py and the Discord bot to call
# /admin/* endpoints. Generate something long and random:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_API_KEY=replace-me-with-a-long-random-secret

# CORS origins (comma-separated). Usually not needed; clients are not browsers.
ALLOWED_ORIGINS=

# Bind address (Uvicorn). Fly.io / Render usually want 0.0.0.0:8080.
HOST=0.0.0.0
PORT=8080
